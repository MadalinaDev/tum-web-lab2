<header
  class="sticky top-0 z-10 bg-[rgba(246,241,234,0.92)] backdrop-blur-[10px] border-b border-line"
>
  <div class="container flex items-center gap-2 py-2 sm:py-5 md:gap-6">
    <a
      class="inline-flex items-center gap-2 sm:gap-3.5 text-inherit no-underline"
      href="#hero"
    >
      <span
        class="inline-flex items-center justify-center w-11 h-11 bg-[#fff1e4] rounded-xl p-1.5 shadow-card"
      >
        <img
          class="w-full h-full object-contain"
          src="/images/mascot.png"
          alt="Mascota"
        />
      </span>
      <span
        class="hidden sm:inline font-display font-semibold leading-tight text-sm md:text-lg"
      >
        {{ site.siteNameFull }}
      </span>
    </a>
    <input
      class="mobile-menu-toggle-input"
      type="checkbox"
      id="mobileMenuToggle"
      aria-label="Toggle menu"
    />
    <label class="mobile-menu-toggle" for="mobileMenuToggle">
      <span></span>
      <span></span>
      <span></span>
    </label>
    <nav class="site-nav" id="siteNav" aria-label="Navigatie principala">
      {% for item in navigation.items %}
      <a href="{{ item.href }}">{{ item.label }}</a>
      {% endfor %}
    </nav>
    <a class="cta" href="#contact">Programeaza o sedinta</a>
  </div>
</header>
