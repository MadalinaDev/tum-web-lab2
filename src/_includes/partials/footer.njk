<footer class="bg-[#1b1b1d] text-[#f5efe6] pt-12">
  <div
    class="container grid grid-cols-1 lg:grid-cols-[1.2fr_0.6fr_0.8fr] gap-6 lg:gap-8 pb-8 border-b border-[rgba(245,239,230,0.2)]"
  >
    <div>
      <p class="font-display text-lg sm:text-xl mb-2.5">
        {{ site.siteName }}
      </p>
      <p
        class="mb-2 text-sm sm:text-base text-[rgba(245,239,230,0.72)] leading-relaxed"
      >
        {{ site.description }}
      </p>
    </div>
    <div class="grid gap-2">
      {% for link in navigation.footerLinks %}
      <a
        class="text-[#f5efe6] no-underline hover:text-[#f0c59b]"
        href="{{ link.href }}"
        >{{ link.label }}</a
      >
      {% endfor %}
    </div>
    <div>
      <p
        class="uppercase text-xs tracking-wide text-[rgba(245,239,230,0.6)] mb-2"
      >
        Contact
      </p>
      <p
        class="mb-2 text-sm sm:text-base text-[rgba(245,239,230,0.72)] leading-relaxed"
      >
        {{ contact.phone }}
      </p>
      <p
        class="mb-2 text-sm sm:text-base text-[rgba(245,239,230,0.72)] leading-relaxed"
      >
        {{ contact.email }}
      </p>
    </div>
  </div>
  <div class="text-center py-4 pb-6 text-[rgba(245,239,230,0.5)] text-sm">
    <p>{{ site.copyright }}</p>
  </div>
</footer>
