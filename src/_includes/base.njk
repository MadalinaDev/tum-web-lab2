<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ site.title }}</title>
    <link rel="icon" type="image/png" href="/images/mascot.png" />
    <link rel="stylesheet" href="/css/reset.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        corePlugins: { preflight: false, container: false },
        theme: {
          screens: { sm: "480px", md: "768px", lg: "1024px" },
          extend: {
            colors: {
              ink: { DEFAULT: "#111215", soft: "#2a2d33" },
              paper: "#f6f1ea",
              accent: { DEFAULT: "#d97a35", dark: "#a4541c" },
              line: "#e5d7c8",
            },
            fontFamily: {
              display: ['"Playfair Display"', "Georgia", "serif"],
              body: ['"Source Sans 3"', "Georgia", "serif"],
            },
            boxShadow: {
              card: "0 18px 40px rgba(17, 18, 21, 0.12)",
            },
          },
        },
      };
    </script>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body
    class="font-body text-ink min-h-screen bg-[radial-gradient(circle_at_top_left,_#fdf7ef_0%,_#f6f1ea_60%)]"
  >
    {% include "partials/header.njk" %}

    <main>
      {{ content | safe }}
    </main>

    {% include "partials/mascot.njk" %}
    {% include "partials/footer.njk" %}
  </body>
</html>
